# ================================
# Application Configuration
# ================================
APP_PORT=3000

# ================================
# MySQL Database Configuration
# ================================
# Use 'localhost' for development outside Docker, use 'db' inside docker-compose
MYSQL_HOST=localhost
# Port 3307 is mapped to 3306 in docker-compose
MYSQL_PORT=3307
MYSQL_USER=gouser
MYSQL_PASSWORD=gosecret123
MYSQL_DATABASE=go_ecommerce_db
MYSQL_ROOT_PASSWORD=rootsecret123

# Database URL for migrations
DB_URL=mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@tcp(${MYSQL_HOST}:${MYSQL_PORT})/${MYSQL_DATABASE}?multiStatements=true

# ================================
# Redis Cache Configuration
# ================================
# Use 'localhost' for development outside Docker, use 'cache' inside docker-compose
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redissecret123

# ================================
# Kafka Configuration
# ================================
# Use Port 9093 for development outside Docker (External Listener)
# Use Port 9092 inside docker-compose (Internal Listener)
KAFKA_BROKER=localhost:9093
KAFKA_HOST=localhost
KAFKA_PORT=9093


# ================================
# JWT Configuration
# ================================
# IMPORTANT: Change this secret key in production!
# Generate secure key using: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

