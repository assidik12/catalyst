# Enforce LF line endings for shell scripts so they work inside Linux containers
# regardless of the developer's OS (Windows uses CRLF by default).
*.sh    text eol=lf

# Go source and config files — LF only
*.go    text eol=lf
*.mod   text eol=lf
*.sum   text eol=lf
*.env   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sql   text eol=lf

# Binary files — no line-ending conversion
*.png   binary
*.jpg   binary
*.gif   binary
